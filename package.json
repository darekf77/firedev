{
  "tnp": {
    "resources": [
      "README.md",
      "projects",
      "bin",
      "logo_github.png",
      "logo.png",
      "files.png"
    ],
    "type": "isomorphic-lib",
    "version": "v2",
    "overrided": {
      "ignoreDepsPattern": [],
      "dependencies": {
        "tnp": "0.0.45"
      },
      "includeAsDev": [],
      "includeOnly": [
        "tnp"
      ]
    },
    "linkedProjects": [],
    "libReleaseOptions": {
      "nodts": false,
      "obscure": false,
      "ugly": false
    }
  },
  "name": "firedev",
  "version": "2.0.61",
  "description": "Isofiredevc solution for expressjs and angular5",
  "main": "index.js",
  "scripts": {
    "release:patch": "npm version patch && tnp clear:bundle && tnp build:bundle && tnp --copy-resources && cd bundle && npm publish && cd .. && git push origin master && echo \"done\"",
    "build:watch": "npm-run watch \"firedev build\" src",
    "build": "./node_modules/.bin/ts-node ./node_modules/typescript-npm-project/index.ts",
    "build:publish": "./node_modules/.bin/ts-node ./node_modules/typescript-npm-project/index.ts --publish",
    "build:clean": "./node_modules/.bin/ts-node ./node_modules/typescript-npm-project/index.ts --clean",
    "test": "mocha -r ts-node/register src/tests/**/*.ts",
    "test:watch": "mocha  -r ts-node/register --watch  src/**/*.spec.ts --watch-extensions ts"
  },
  "bin": {
    "firedev": "bin/firedev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darekf77/firedev.git"
  },
  "author": "Dariusz Filipiak",
  "bugs": {
    "url": "https://github.com/darekf77/firedev/issues"
  },
  "homepage": "https://github.com/darekf77/firedev#readme",
  "husky": {
    "hooks": {
      "pre-push": "tnp deps:show:if:standalone"
    }
  },
  "devDependencies": {
    "@types/node": "10.12.30",
    "babel-core": "^6.25.0",
    "babel-loader": "^7.1.1",
    "babel-plugin-syntax-dynamic-import": "^6.18.0",
    "babel-preset-env": "^1.6.1",
    "babel-preset-es2015": "^6.24.1",
    "enum-values": "1.2.1",
    "reflect-metadata": "^0.1.10",
    "ts-node": "^7.0.1",
    "tslib": "^1.8.1",
    "tslint": "^5.9.1",
    "typescript": "2.6.2"
  },
  "dependencies": {
    "tnp": "0.0.45"
  },
  "license": "MIT",
  "private": false
}
